# 应用
APP_NAME=抖音留资直播分析系统
APP_VERSION=0.1.0
DEBUG=true

# MySQL / Redis（与 docker-compose.yml 默认配置一致）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=douyin_live
REDIS_URL=redis://localhost:6379

# AI：请填写自己的密钥，不要把真实密钥提交到 Git
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com

# Playwright 与实时监控
PLAYWRIGHT_HEADLESS=true
ROOM_COLLECTION_TIMEOUT_SECONDS=90
MONITOR_ENABLED=true
MONITOR_MOCK_MODE=false
MONITOR_CHECK_INTERVAL=120
METRICS_COLLECT_INTERVAL=30
COMMENT_COLLECT_INTERVAL=60
PROFILE_COLLECT_INTERVAL=120

# FunASR：8GB 电脑建议保持单任务，使用完即在页面关闭
FUNASR_WS_URL=ws://localhost:10096
ASR_AUTO_START=true
MAX_REALTIME_ASR_TASKS=1
ASR_MAX_QUEUED=5
ASR_ENGINE_READY_TIMEOUT_SECONDS=300
ASR_TASK_TIMEOUT_SECONDS=600
ASR_NO_AUDIO_TIMEOUT_SECONDS=30
ASR_ALLOW_MOCK=false
SAVE_AUDIO=false
SAVE_VIDEO=false

# 登录令牌：正式部署前必须替换为随机长字符串
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
