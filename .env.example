# ============================================
# 抖音留资直播分析系统 — 后端配置文件（模板）
# ============================================
# 使用方式：cp .env.example .env 然后填写真实值
# 前端变量请参考 frontend/.env（VITE_* 变量会暴露到浏览器，务必不要把密钥放进去！）
# 正式部署前务必修改所有密钥和密码！

# ============================================
#  一、应用基础
# ============================================
APP_NAME=零食店避坑直播运营复盘系统
APP_VERSION=0.1.0
DEBUG=false
ALLOW_SYNTHETIC_DATA=false
LOG_FORMAT=json
OBSERVABILITY_ENABLED=true

# ============================================
#  二、数据库（MySQL 8）
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=请替换为至少16位随机密码
DB_NAME=douyin_live
DATABASE_ECHO=false
DATAEASE_READER_USER=dataease_reader
DATAEASE_READER_PASSWORD=请修改为仅供DataEase使用的强密码

# ============================================
#  三、Redis
# ============================================
REDIS_URL=redis://localhost:6379
TASK_EVENT_STREAM=douyin:task-events
TASK_EVENT_STREAM_MAXLEN=10000
TASK_HEARTBEAT_TIMEOUT_SECONDS=180

# ============================================
#  四、DeepSeek AI 分析
# ============================================
# 请填写自己的密钥，不要把真实密钥提交到 Git
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com

# ============================================
#  五、ASR 语音转写（FunASR）
# ============================================
# 8GB 电脑建议保持单任务，使用完即在页面关闭
FUNASR_WS_URL=ws://localhost:10096
ASR_AUTO_START=true
MAX_REALTIME_ASR_TASKS=1
ASR_MAX_QUEUED=5
ASR_ENGINE_READY_TIMEOUT_SECONDS=300
ASR_TASK_TIMEOUT_SECONDS=600
ASR_NO_AUDIO_TIMEOUT_SECONDS=30
ASR_CHUNK_SECONDS=300
ASR_CHUNK_MAX_RETRIES=2
ASR_ALLOW_MOCK=false
SAVE_AUDIO=false
SAVE_VIDEO=false
KNOWLEDGE_SLICE_SECONDS=300

# ============================================
#  六、Playwright / 直播采集监控
# ============================================
PLAYWRIGHT_HEADLESS=true
ROOM_COLLECTION_TIMEOUT_SECONDS=90
MONITOR_ENABLED=true
MONITOR_MOCK_MODE=false
MONITOR_CHECK_INTERVAL=120
METRICS_COLLECT_INTERVAL=30
COMMENT_COLLECT_INTERVAL=60
PROFILE_COLLECT_INTERVAL=120

# ============================================
#  七、JWT 认证
# ============================================
# DEBUG=false 时必须是至少 32 位的随机字符串，否则后端拒绝启动
JWT_SECRET_KEY=请替换为至少32位随机字符串
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
#  八、Grafana 监控面板
# ============================================
# 一键启动会启用可观测性组件，首次启动前必须修改
GRAFANA_ADMIN_PASSWORD=请替换为至少16位随机密码

# ============================================
#  九、跨域与部署
# ============================================
# 部署到服务器时，把 localhost 替换为实际前端域名
CORS_ORIGINS=http://localhost:9527,http://127.0.0.1:9527
BACKEND_RELOAD=false

