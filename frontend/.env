# ============================================
# 零食店直播运营系统 — 前端 Vite 配置
# ============================================
# 后端变量在项目根目录 .env，前端变量在本文件
# ⚠️ 只有 VITE_* 前缀的变量会暴露到浏览器，不要把密钥放这里！
# Vite 加载顺序：.env → .env.[mode] → .env.[mode].local（后者覆盖前者）

# -- 基础配置 --
VITE_BASE_URL=/                                      # 应用基础路径（子目录部署时改为 /admin/）
VITE_APP_TITLE=零食店直播运营系统                    # 浏览器标签页标题
VITE_APP_DESC=抖音留资直播数据复盘工具 — AI 话术分析 + 实时大屏   # 应用描述

# -- DataEase 数据大屏 --
VITE_DATAEASE_URL=http://localhost:8100               # DataEase 已发布大屏分享地址（含 # 的 URL 必须加引号）

# -- 图标 --
VITE_ICON_PREFIX=icon                                 # 图标前缀（与 iconify 集成）
VITE_ICON_LOCAL_PREFIX=icon-local                     # 本地 SVG 图标前缀
VITE_MENU_ICON=mdi:menu                               # 默认菜单图标（mdi = Material Design Icons）

# -- 路由 --
VITE_AUTH_ROUTE_MODE=static                           # 路由权限模式：static（前端定义）/ dynamic（后端返回）
VITE_ROUTE_HOME=home                                  # 静态模式下首页路由名
VITE_ROUTER_HISTORY_MODE=history                      # Vue Router 模式：history / hash / memory

# -- HTTP 代理（仅开发模式生效）--
VITE_HTTP_PROXY=Y                                     # 开发模式是否开启 HTTP 代理（Y/N）
VITE_PROXY_LOG=Y                                      # 终端是否打印代理日志（Y/N）

# -- 后端服务对接 --
VITE_SERVICE_BASE_URL=http://localhost:8000           # 后端 API 基础地址
VITE_SERVICE_SUCCESS_CODE=0000                        # 后端返回的成功状态码
VITE_SERVICE_LOGOUT_CODES=8888,8889                   # 后端返回的登出状态码（逗号分隔）
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778             # 后端返回的弹窗登出状态码
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999,9998,3333       # Token 过期状态码（自动刷新 token 并重发请求）
VITE_OTHER_SERVICE_BASE_URL={"backend":"http://localhost:8000"}   # 其他后端服务地址（JSON 格式）

# -- 静态路由超级角色 --
VITE_STATIC_SUPER_ROLE=R_SUPER                        # 静态路由模式下拥有所有权限的角色

# -- Source Map --
VITE_SOURCE_MAP=N                                     # 生产构建是否生成 source map（Y/N）

# -- 本地存储 --
VITE_STORAGE_PREFIX=SOY_                              # localStorage 前缀（区分不同域名部署）

# -- 自动更新检测 --
VITE_AUTOMATICALLY_DETECT_UPDATE=Y                    # 是否自动检测新版本并提示刷新（Y/N）

# -- 开发工具 --
VITE_DEVTOOLS_LAUNCH_EDITOR=code                      # 开发模式下启动的编辑器（code = VS Code）

# -- 内网部署（可选）--
# VITE_ICONIFY_URL=                                   # 自建 Iconify API 地址（内网无外网时取消注释并填写）
